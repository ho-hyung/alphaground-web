# ───────────────────────────────────────────────────
# AlphaGround 환경 변수 (Vercel / 로컬 개발용)
#
# 이 파일을 복사하여 .env.local 로 저장하고 값을 채우세요.
# .env.local 은 절대 git 에 커밋하지 마세요.
# ───────────────────────────────────────────────────

# ── [필수] 국토부 실거래가 API ──────────────────────
# https://www.data.go.kr/data/15058747/openapi.do
MOLIT_API_KEY=

# ── [선택] Supabase (Phase 2 — DB 연동 시 필요) ────
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
SUPABASE_URL=
SUPABASE_ANON_KEY=
# 서버사이드 전용 (Service Role Key — 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# ── [선택] Google Maps (지도 기능 활성화 시) ────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── [선택] Kakao Maps ─────────────────────────────
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=

# ── [선택] 분석 (Vercel Analytics 등) ──────────────
NEXT_PUBLIC_ANALYTICS_ID=

PORTONE_API_SECRET=
PORTONE_CHANNEL_KEY=
PORTONE_WEBHOOK_SECRET=
PORTONE_MEMBERSHIP_PRICE=
