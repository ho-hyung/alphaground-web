# ───────────────────────────────────────────────────
# AlphaGround 환경 변수 (Vercel / 로컬 개발용)
#
# 이 파일을 복사하여 .env.local 로 저장하고 값을 채우세요.
# .env.local 은 절대 git 에 커밋하지 마세요.
# ───────────────────────────────────────────────────

# ── [필수] Supabase ─────────────────────────────────
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
# https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# 서버사이드 전용 (Service Role Key — 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── [선택] 국토부 실거래가 API ──────────────────────
# https://www.data.go.kr/data/15058747/openapi.do
MOLIT_API_KEY=

# ── [선택] Google Maps (지도 기능 활성화 시) ────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── [선택] Kakao Maps ─────────────────────────────
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=

# ── [선택] 분석 (Vercel Analytics 등) ──────────────
NEXT_PUBLIC_ANALYTICS_ID=

# ── [필수] 포트원(PortOne) v2 결제 연동 ─────────────
# test.portone.io > 내 식별코드 & API Keys 에서 확인
# 테스트 모드: https://admin.portone.io/settings/api-keys
PORTONE_API_SECRET=sk_test_...
# 채널 관리 > 채널 목록 > 채널 키 (토스페이먼츠 또는 카카오페이)
PORTONE_CHANNEL_KEY=channel-key-...
# 얼리버드 멤버십 가격 (KRW, 정수)
PORTONE_MEMBERSHIP_PRICE=49000
# Webhook 서명 검증 시크릿: 포트원 관리자 > 결제 연동 > Webhook > 시크릿 키
PORTONE_WEBHOOK_SECRET=whsec_...

# ── [결제 캠페인] 이메일 발송 ──────────────────────
# Resend 또는 SendGrid 중 하나를 설정하세요
# https://resend.com/api-keys
RESEND_API_KEY=re_...
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....
# 발신자 주소 (예: AlphaGround <hello@alphaground.kr>)
EMAIL_FROM=AlphaGround <hello@alphaground.kr>

# ── 내부 Cron / Admin API 인증 시크릿 ───────────────
# 랜덤 문자열로 직접 생성: openssl rand -hex 32
CRON_SECRET=your-secret-here

# ── 관리자 이메일 (/admin/* 페이지 접근 제한) ─────────
# 설정하면 해당 이메일로 로그인한 사용자만 /admin/* 접근 가능
# 비워두면 로그인한 모든 사용자가 접근 가능 (개발 환경용)
ADMIN_EMAIL=your-admin@example.com
